{
  "name": "nextjs-starter",
  "description": "A Next.js starter that includes all you need to build amazing projects",
  "version": "1.0.0",
  "private": true,
  "author": "abel chang<cwuyiqing@gmail.com>",
  "license": "MIT",
  "keywords": [
    "nextjs",
    "starter",
    "typescript"
  ],
  "scripts": {
    "dev": "next",
    "build": "next build",
    "start": "next start",
    "export": "next build && next export",
    "lint": "eslint --ignore-path .gitignore --fix",
    "compile": "hardhat compile && hardhat copy-artifacts",
    "format": "prettier --ignore-path .gitignore \"pages/**/*.+(ts|js|tsx)\" --write",
    "postinstall": "husky install",
    "test": "NODE_ENV=test hardhat test"
  },
  "lint-staged": {
    "./**/*.{ts,js,jsx,tsx}": [
      "pnpm run lint",
      "pnpm run format"
    ]
  },
  "dependencies": {
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.11.5",
    "@fontsource/roboto": "5.0.13",
    "@mui/icons-material": "5.16.0",
    "@mui/material": "5.16.0",
    "@nomicfoundation/hardhat-chai-matchers": "2.0.7",
    "@nomiclabs/hardhat-ethers": "2.2.3",
    "@nomiclabs/hardhat-waffle": "2.0.6",
    "@types/chai": "4.3.16",
    "@types/formidable": "3.4.5",
    "@types/fs-extra": "11.0.4",
    "@types/klaw": "3.0.6",
    "@types/mocha": "10.0.7",
    "axios": "1.7.2",
    "dotenv": "16.4.5",
    "ethers": "6.13.1",
    "formidable": "3.5.1",
    "framer-motion": "11.2.11",
    "mui-file-input": "4.0.6",
    "next": "14.2.4",
    "next-compose-plugins": "2.2.1",
    "next-images": "1.8.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp-watermark": "0.5.3",
    "zksync-ethers": "6.9.0"
  },
  "devDependencies": {
    "@matterlabs/hardhat-zksync": "1.1.0",
    "@matterlabs/hardhat-zksync-deploy": "1.5.0",
    "@matterlabs/hardhat-zksync-ethers": "1.1.0",
    "@matterlabs/hardhat-zksync-solc": "1.2.0",
    "@matterlabs/hardhat-zksync-verify": "1.6.0",
    "@openzeppelin/contracts": "4.6.0",
    "@openzeppelin/contracts-upgradeable": "4.6.0",
    "@types/node": "20.14.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "autoprefixer": "10.4.19",
    "eslint": "9.5.0",
    "eslint-config-alloy": "5.1.2",
    "eslint-config-next": "14.2.4",
    "file-loader": "6.2.0",
    "fs-extra": "11.2.0",
    "hardhat": "2.22.6",
    "husky": "9.0.11",
    "klaw": "4.1.0",
    "lint-staged": "15.2.7",
    "node-loader": "2.0.0",
    "postcss": "8.4.38",
    "prettier": "3.3.2",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "url-loader": "4.1.1"
  }
}
